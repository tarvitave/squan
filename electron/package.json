{
  "name": "squan",
  "version": "2.5.2",
  "description": "Squan — AI-powered multi-agent development command center",
  "author": "Squan",
  "license": "MIT",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && electron dist/main.js",
    "build": "tsc",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-store": "^10.0.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "typescript": "^5.5.4"
  },
  "build": {
    "appId": "com.squan.desktop",
    "productName": "Squan",
    "directories": {
      "output": "../release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../server/dist",
        "to": "server",
        "filter": ["**/*"]
      },
      {
        "from": "../server/node_modules",
        "to": "server/node_modules",
        "filter": ["**/*"]
      },
      {
        "from": "../client/dist",
        "to": "client",
        "filter": ["**/*"]
      },
      {
        "from": "../server/.env",
        "to": "server/.env",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
